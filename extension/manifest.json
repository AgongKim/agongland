{
  "manifest_version": 3,
  "name": "아공랜드 채팅",
  "version": "1.0.0",
  "description": "아공랜드 채팅서비스",
  "action": {
    "default_popup": "popup.html",
    "default_title": "아공랜드 채팅"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://localhost:8080/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": [
        "src/state.js",
        "src/nickname.js",
        "src/songs.js",
        "src/recs.js",
        "src/chat.js",
        "src/panel.js",
        "src/connection.js",
        "src/main.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
