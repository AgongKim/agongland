{
  "manifest_version": 3,
  "name": "아공랜드 채팅",
  "version": "1.0.0",
  "description": "아공랜드 채팅서비스",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content_script.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
